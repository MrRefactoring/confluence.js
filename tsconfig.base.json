{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "stripInternal": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  }
}
